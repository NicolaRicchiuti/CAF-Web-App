// =========================================================
// 4. CARICA ORARI DINAMICI (Aggiornato con Blocchi e Nuovi Orari)
// =========================================================
async function caricaOrariDinamici(idAgente, data, durataServizio) {
    const container = document.getElementById('orari-container');
    container.innerHTML = `<div class="spinner-border text-primary spinner-border-sm"></div> Calcolo disponibilità...`;

    // 1. Recupera appuntamenti esistenti per quella data e agente
    const { data: appuntamentiEsistenti, error: errorApp } = await _supabase
        .from('appuntamenti')
        .select('ora, servizio_id') 
        .eq('agente_id', idAgente)
        .eq('data', data);

    // 2. Recupera i BLOCCHI (ferie/indisponibilità) per quella data e agente
    const { data: blocchiEsistenti, error: errorBlocchi } = await _supabase
        .from('blocchi')
        .select('ora_inizio, ora_fine')
        .eq('agente_id', idAgente)
        .eq('data', data);

    if (errorApp || errorBlocchi) { 
        console.error("Errore Supabase:", errorApp || errorBlocchi);
        container.innerHTML = `<div class="text-danger small">Errore caricamento orari.</div>`; 
        return; 
    }

    // 3. Definisce le Fasce Orarie (aggiornate 10-12 e 16-18:30)
    const fasceApertura = [
        { nome: 'MATTINA (10:00 - 12:00)', id: 'mattina', inizio: 600, fine: 720 },
        { nome: 'POMERIGGIO (16:00 - 18:30)', id: 'pomeriggio', inizio: 960, fine: 1110 }
    ];

    // 4. Mappa appuntamenti e blocchi in un'unica lista di "slot occupati"
    let occupati = [];

    // Aggiungiamo gli appuntamenti (con durata fissa a 30 min per sicurezza)
    appuntamentiEsistenti.forEach(app => {
        const minutiInizio = timeToMinutes(app.ora);
        occupati.push({ start: minutiInizio, end: minutiInizio + 30 });
    });

    // Aggiungiamo i blocchi
    blocchiEsistenti.forEach(blocco => {
        const inizioBlocco = timeToMinutes(blocco.ora_inizio);
        const fineBlocco = timeToMinutes(blocco.ora_fine);
        occupati.push({ start: inizioBlocco, end: fineBlocco });
    });

    // 5. Costruisce l'HTML della Fisarmonica (Accordion)
    let htmlAccordion = `<div class="accordion" id="accordionOrari">`;
    let slotTotaliTrovati = 0;
    const step = 15; // Intervallo slot: 15 minuti
    let isFirstOpen = true; 

    fasceApertura.forEach((fascia) => {
        let htmlButtons = '';
        
        // Genera i bottoni per questa fascia
        for (let time = fascia.inizio; time < fascia.fine; time += step) {
            const slotStart = time;
            const slotEnd = time + durataServizio;

            if (slotEnd > fascia.fine) continue; 

            let sovrapposizione = false;
            for (let occ of occupati) {
                // Controllo magico: si sovrappone a un appuntamento o a un blocco?
                if (slotStart < occ.end && slotEnd > occ.start) {
                    sovrapposizione = true;
                    break;
                }
            }

            const oraStringa = minutesToTime(slotStart);

            if (sovrapposizione) {
                // Slot occupato/bloccato: bottone disabilitato
                htmlButtons += `<button class="btn btn-secondary disabled-slot w-100" disabled style="opacity:0.3; font-size:0.8rem;">${oraStringa} (Non disponibile)</button>`;
            } else {
                // Slot libero: bottone cliccabile
                htmlButtons += `
                    <button class="btn btn-outline-success w-100 fw-bold" onclick="selezionaOra('${oraStringa}', this)">
                        ${oraStringa}
                    </button>`;
            }
        }

        // Aggiungiamo il pannello solo se ci sono slot
        if (htmlButtons !== '') {
            slotTotaliTrovati++;
            const collapseId = `collapse${fascia.id}`;
            const headingId = `heading${fascia.id}`;
            
            const showClass = isFirstOpen ? 'show' : '';
            const collapsedClass = isFirstOpen ? '' : 'collapsed';
            if (isFirstOpen) isFirstOpen = false; 

            htmlAccordion += `
                <div class="accordion-item">
                    <h2 class="accordion-header" id="${headingId}">
                        <button class="accordion-button ${collapsedClass}" type="button" data-bs-toggle="collapse" data-bs-target="#${collapseId}" aria-expanded="${showClass === 'show'}" aria-controls="${collapseId}">
                            ${fascia.nome}
                        </button>
                    </h2>
                    <div id="${collapseId}" class="accordion-collapse collapse ${showClass}" aria-labelledby="${headingId}" data-bs-parent="#accordionOrari">
                        <div class="accordion-body">
                            <div class="slots-scroll-container"> 
                                <div class="d-grid gap-2"> ${htmlButtons}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }
    });

    htmlAccordion += `</div>`; 

    if (slotTotaliTrovati === 0) {
        container.innerHTML = `<div class="alert alert-warning mt-3">Nessuna disponibilità in questa data.</div>`;
    } else {
        container.innerHTML = htmlAccordion;
    }
}

// =========================================================
// 5. FUNZIONI HELPER TEMPO (Minuti <-> Stringa)
// =========================================================
function timeToMinutes(timeStr) {
    const [h, m] = timeStr.split(':').map(Number);
    return h * 60 + m;
}

function minutesToTime(minutes) {
    const h = Math.floor(minutes / 60);
    const m = minutes % 60;
    return `${h.toString().padStart(2, '0')}:${m.toString().padStart(2, '0')}`;
}

// =========================================================
// 6. GESTIONE SELEZIONE E UI
// =========================================================
function selezionaOra(ora, btnElement) {
    // Salva l'ora scelta
    document.getElementById('tempOra').value = ora;
    
    // Mostra il form
    document.getElementById('form-dati-utente').style.display = 'block';

    const container = document.getElementById('orari-container');
    const allBtns = container.querySelectorAll('.btn-outline-success, .btn-success');
    
    allBtns.forEach(b => {
        b.classList.remove('active', 'btn-success'); 
        b.classList.add('btn-outline-success');
    });
    
    btnElement.classList.remove('btn-outline-success');
    btnElement.classList.add('btn-success', 'active');
    
    // Scroll fluido verso il form
    document.getElementById('form-dati-utente').scrollIntoView({ behavior: 'smooth' });
}

