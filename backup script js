// 7. SALVATAGGIO FINALE (Aggiornato con Telefono e Messaggio "In Attesa")
// =========================================================
async function salvaPrenotazioneFinale(idAgente, idServizio) {
    const data = document.getElementById('tempData').value;
    const ora = document.getElementById('tempOra').value;
    const nome = document.getElementById('nome').value;
    const email = document.getElementById('email').value;
    const telefono = document.getElementById('telefono').value; // Recupero il telefono

    if (!data || !ora || !nome || !email || !telefono) { 
        alert("Compila tutti i campi, incluso il cellulare!"); 
        return; 
    }

    const modalBody = document.getElementById('modalCorpo');
    modalBody.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary"></div><p class="mt-3">Invio richiesta in corso...</p></div>';

    const { error } = await _supabase.from('appuntamenti').insert({
        agente_id: idAgente,
        servizio_id: idServizio,
        data: data,
        ora: ora,
        nome_cliente: nome,
        email_cliente: email,
        telefono: telefono // Salva il telefono nel database
    });

    if (error) {
        if (error.code === '23505') { 
             modalBody.innerHTML = `
                <div class="alert alert-warning text-center">
                    <h4>⚠️ Slot non più disponibile</h4>
                    <p>Qualcun altro ha prenotato in questo intervallo.</p>
                    <button class="btn btn-primary" onclick="location.reload()">Riprova</button>
                </div>`;
        } else {
            modalBody.innerHTML = `<div class="alert alert-danger">Errore: ${error.message}</div><button class="btn btn-secondary" onclick="location.reload()">Chiudi</button>`;
        }
    } else {
        // MESSAGGIO AGGIORNATO PER L'ACCETTAZIONE
        modalBody.innerHTML = `
            <div class="text-center py-4">
                <h1 class="display-1 text-warning">⏳</h1>
                <h3 class="mt-2">Richiesta Inviata!</h3>
                <p class="lead">Hai richiesto un appuntamento per il <b>${data}</b> alle <b>${ora}</b>.</p>
                <p class="text-muted">La tua prenotazione è in attesa di accettazione da parte del nostro team.<br>Riceverai presto una conferma su WhatsApp.</p>
                <button class="btn btn-primary mt-3" onclick="location.reload()">Chiudi e Torna alla Home</button>
            </div>
        `;
    }
}