// 2. MOSTRA SERVIZI (Modale Step 1)
// =========================================================
async function mostraServiziAgente(idAgente, nomeAgente) {
    const modalElement = document.getElementById('modalServizi');
    const modal = new bootstrap.Modal(modalElement);
    modal.show();

    document.getElementById('modalTitolo').innerText = `Servizi di ${nomeAgente}`;
    const modalBody = document.getElementById('modalCorpo');
    modalBody.innerHTML = '<div class="text-center"><div class="spinner-border"></div></div>';

    // Recupera i servizi tramite la tabella di relazione 'competenze'
    const { data, error } = await _supabase
        .from('competenze')
        .select(`servizi (id, nome, durata)`)
        .eq('agente_id', idAgente);

    if (error || !data) {
        modalBody.innerHTML = `<p class="text-danger">Errore caricamento servizi.</p>`;
        return;
    }

    // SALVA IN CACHE: Fondamentale per calcolare dopo le durate degli appuntamenti esistenti
    window.serviziCache = data.map(item => item.servizi);

    let htmlLista = '<div class="list-group">';
    data.forEach(riga => {
        const servizio = riga.servizi; 
        if (!servizio) return;
        
        // Al click passiamo ID e DURATA del servizio scelto
        htmlLista += `
            <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                onclick="setupPrenotazione('${idAgente}', '${servizio.id}', ${servizio.durata})">
                ${servizio.nome}
                <span class="badge rounded-pill">${servizio.durata} min</span>
            </button>
        `;
    });
    htmlLista += '</div>';
    modalBody.innerHTML = htmlLista;
}

